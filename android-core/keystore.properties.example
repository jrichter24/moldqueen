# moldqueen — LOCAL release signing template.
#
# Copy this to `keystore.properties` (same dir) and fill in REAL values. The real
# keystore.properties is GITIGNORED and must NEVER be committed. NEVER commit a keystore
# or a password. For CI signing, use the MOLDQUEEN_* env vars instead (see dev-docs/ANDROID.md).
#
# The keystore is a PKCS12 (.p12) kept OUTSIDE the repo. If neither this file nor the
# MOLDQUEEN_* env vars are present, `assembleRelease` produces an UNSIGNED APK and still
# succeeds (the CI test gate + F-Droid from-source both rely on that).

# Absolute path to the .p12 keystore (recommended; it lives outside the repo).
storeFile=/absolute/path/to/moldqueen-release.p12
storePassword=CHANGE_ME
keyAlias=moldqueen
keyPassword=CHANGE_ME
